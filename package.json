{
    "name": "lynn-mata-ui-design",
    "version": "0.0.2",
    "type": "module",
    "description": "Vue 3 UI Library for Mata Education",
    "main": "./dist/mata-ui.umd.js",
    "module": "./dist/mata-ui.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/mata-ui.mjs",
            "require": "./dist/mata-ui.umd.js"
        },
        "./style.css": "./dist/style.css"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "deploy:cf": "npm run docs:build && npx wrangler pages deploy docs/.vitepress/dist"
    },
    "peerDependencies": {
        "vue": "^3.3.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "autoprefixer": "^10.0.0",
        "postcss": "^8.0.0",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.0.0",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^4.5.4",
        "vitepress": "^1.6.4",
        "vue": "^3.5.27",
        "vue-tsc": "^2.0.0"
    },
    "dependencies": {
        "vue": "^3.3.0"
    }
}